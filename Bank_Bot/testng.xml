<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite" parallel="tests" thread-count="5">

<listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>
    
<!-- Test Module-1 -->
    <test name="Login Tests">
        <classes>
            <class name="tests.LoginTest"/>
        </classes>
    </test> 
    
<!-- Test Module-2 -->
    <test name="Customer Module Tests">
        <classes>
            <class name="tests.CustomerTest"/>
        </classes>
    </test> 
    
 <!-- Test Module-3-->   
    <test name="Account Module Tests">
        <classes>
            <class name="tests.AccountTest"/>
        </classes>
    </test>
    
<!-- Test Module-4--> 
<test name="Fund Transfer Tests">
        <classes>
            <class name="tests.FundTransferTest"/>
        </classes>
    </test> 
</suite> <!-- Suite -->
